# Backend ortam değişkenleri — ".env" olarak kopyalayın, repoya commit etmeyin.

# CORS (virgülle ayrılmış frontend kökenleri)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase (yalnızca sunucu tarafı — service role asla frontend'e gitmez)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (Faz 3+)
GEMINI_API_KEY=
